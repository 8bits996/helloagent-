          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【第二部分：What - 认识AI智能体 - 8分钟】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【AI Agent核心架构】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>AI Agent = Brain(控制端) + Perception(感知端) + Action(行动端)</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【Brain组件 - 大脑/LLM】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>核心职责：推理、规划、决策</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>关键能力：</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- Planning：任务分解、子目标规划</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- Reflection：自我反思、错误修正</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【Memory组件 - 记忆系统】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>短期记忆：上下文窗口，Prompt工程</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>长期记忆：向量数据库，RAG检索</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【Tool Use组件 - 工具调用】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>API调用：访问外部服务</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>代码执行：数据处理、计算</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>数据库查询：业务数据获取</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【架构师视角的设计决策】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>三个组件的选型直接影响Agent能力上限：</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- Brain选型：模型能力 vs 成本 vs 延迟</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- Memory设计：向量库选型、索引策略、分块方案</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- Tool设计：API粒度、错误处理、重试机制</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【参考资料】</a:t>
            </a:r>
          </a:p>
