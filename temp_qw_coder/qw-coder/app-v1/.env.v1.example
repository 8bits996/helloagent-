# 企业微信回调服务 V1 配置示例
# 复制此文件为 .env 并填入实际值

# ========== 企业微信配置 ==========
# 企业微信回调 Token
QYWX_TOKEN=you_token

# 企业微信消息加密密钥（Base64格式，不含末尾的=）
QYWX_ENCODING_AES_KEY=UVlXWF9FTkNPRElOR19BR1123VNfS0VZ

# ========== 服务配置 ==========
# 服务监听端口（默认 8088）
PORT=8088

# ========== 权限配置 ==========
# 白名单用户（企业微信用户别名，逗号分隔）
ALLOWED_USERS=xxx

# ========== 使用说明 ==========
# 1. 复制此文件: cp .env.v1.example .env
# 2. 填写实际配置值
# 3. 加载环境变量: source .env 或 export $(cat .env | xargs)
# 4. 启动服务: python app-v1.py
