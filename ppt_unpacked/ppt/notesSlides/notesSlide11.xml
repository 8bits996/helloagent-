        <p:txBody>
          <a:bodyPr/>
          <a:lstStyle/>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【3.4 核心能力：RAG检索增强 - 10分钟】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【RAG核心价值】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>解决大模型的两大痛点：</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>1. 知识截止：模型训练数据有时效性</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>2. 幻觉问题：模型可能&quot;编造&quot;信息</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【RAG三阶段流程详解】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>1. 索引（Indexing）阶段</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   文档解析：PDF、Word、网页等格式支持</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   文本分块：Chunk策略是关键</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   向量化：Embedding模型选择</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   创建索引：向量数据库存储</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>2. 检索（Retrieval）阶段</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   问题向量化：用户Query转向量</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   相似度计算：余弦相似度等</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   Top-K召回：返回最相关文档</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>3. 生成（Generation）阶段</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   上下文组装：构建增强Prompt</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   LLM生成：基于上下文回答</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【架构师重点关注】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>分块策略：大小、重叠、边界处理</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>Embedding选型：多语言、领域适配</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>向量库选型：Milvus、Pinecone、Chroma</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>重排序：Rerank提升精度</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【经典名言】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>&quot;一周出Demo，半年用不好&quot;</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>RAG调优需要持续投入！</a:t>
            </a:r>
          </a:p>
        </p:txBody>
      </p:sp>
