          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【3.3 核心能力：Prompt工程 - 5分钟】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【Prompt的本质】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>对于架构师来说，Prompt工程就像是在为AI编程：</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>传统编程：精确的语法、确定性执行</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>Prompt编程：自然语言、概率性输出</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【Prompt工程最佳实践】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>1. 角色设定</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   明确AI的身份和专业领域</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   示例：&quot;你是一位专业的合同评审专家...&quot;</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>2. 任务描述</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   清晰、具体、可执行</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   避免模糊的指令</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>3. 输出格式</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   指定结构化输出格式</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   使用JSON/Markdown等标准格式</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>4. 示例引导</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   Few-shot learning</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>   提供输入输出示例</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【推荐学习资源】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>https://www.promptingguide.ai/zh</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>系统化的Prompt工程指南，包含各种高级技巧</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【架构师建议】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>将Prompt作为代码管理，版本控制</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>建立Prompt模版库，团队复用</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>持续优化，A/B测试效果</a:t>
            </a:r>
          </a:p>
