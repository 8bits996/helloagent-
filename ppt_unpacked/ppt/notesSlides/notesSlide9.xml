          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【3.2 核心能力：流程节点详解 - 10分钟】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【节点分类体系】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>输入输出节点：</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 开始/结束：工作流边界定义</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 回答：即时响应用户</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>AI能力节点：</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- LLM：调用大模型，核心推理节点</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 知识检索：RAG实现，对接知识库</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 问题分类器：意图识别和路由分发</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>逻辑控制节点：</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 条件分支：IF/ELSE业务逻辑</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 迭代：批量处理、循环执行</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>数据处理节点：</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 代码：Python/JavaScript执行</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 模板：格式化输出生成</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 参数提取：结构化信息抽取</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【性能优化建议（架构师必知）】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>LLM节点优化：</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 控制温度参数提高稳定性</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 限制最大生成长度</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 启用响应缓存</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>知识检索优化：</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 设置合理返回数量(3-5条)</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 调整相似度阈值(0.7-0.8)</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 启用Rerank重排序</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>HTTP请求优化：</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 设置合理超时时间</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 添加重试机制</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>- 缓存常用结果</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:endParaRPr lang="zh-CN" altLang="en-US" dirty="0"/>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>【实践原则】</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
              <a:rPr lang="zh-CN" altLang="en-US" dirty="0"/>
              <a:t>搭积木，拼乐高 - 但要注意积木的组合方式！</a:t>
            </a:r>
          </a:p>
        </p:txBody>
