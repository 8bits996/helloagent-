# 企业微信配置
# 请从企业微信管理后台获取以下信息：
# 1. 登录 https://work.weixin.qq.com/
# 2. 进入「应用管理」→「自建应用」
# 3. 在应用详情页找到「接收消息」配置部分
export QYWX_TOKEN=请替换为你的企业微信回调Token

# 企业微信消息加密密钥（Base64格式，不含末尾的=）
# 在企业微信应用详情页的「消息加密」部分获取
export QYWX_ENCODING_AES_KEY=请替换为你的EncodingAESKey

# 接收消息的用户白名单（企业微信用户ID，逗号分隔）
export QYWX_RECEIVE_ID=你的RTX

# 服务配置
export HOST=0.0.0.0
export PORT=8088

# CodeBuddy 配置
export CODEBUDDY_PATH=/root/.nvm/versions/node/v22.21.1/bin/codebuddy
export CODEBUDDY_TIMEOUT=300
export WORKING_DIR=/root/workspace/qw-coder