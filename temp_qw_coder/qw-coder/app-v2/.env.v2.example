# 企业微信回调服务 V2 配置示例
# 复制此文件为 .env 并填入实际值

# ========== 企业微信配置 ==========
# 企业微信回调 Token
export QYWX_TOKEN=企业微信回调 Token

# 企业微信消息加密密钥（Base64格式，不含末尾的=）
export QYWX_ENCODING_AES_KEY=企业微信消息加密密钥

# ========== 服务配置 ==========
# 服务监听端口（默认 8088，避免与 V1 冲突）
export PORT=8088

# ========== 权限配置 ==========
# 白名单用户（企业微信用户别名，逗号分隔）
export ALLOWED_USERS=rtxid

# ========== CodeBuddy 配置 ==========
# CodeBuddy 可执行文件路径
export CODEBUDDY_PATH=/root/.nvm/versions/node/v22.21.1/bin/codebuddy

# CodeBuddy 执行超时时间（秒）
export CODEBUDDY_TIMEOUT=300

# CodeBuddy 工作目录
export WORKING_DIR=/root/workspace/qw-coder

# ========== 使用说明 ==========
# 1. 复制此文件: cp .env.v2.example .env
# 2. 填写实际配置值
# 3. 加载环境变量: source .env
# 4. 启动服务: ./start-v2.sh 或 python3 -m uvicorn app-v2:app --host 0.0.0.0 --port 8088
